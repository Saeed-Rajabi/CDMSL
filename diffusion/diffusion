import torch


class DiffusionModel:
    def __init__(self, timesteps: int = 1000):
        self.timesteps = timesteps
        self.beta = torch.linspace(1e-4, 0.02, timesteps)
        self.alpha = 1.0 - self.beta
        self.alpha_hat = torch.cumprod(self.alpha, dim=0)

    def to(self, device: str):
        self.beta = self.beta.to(device)
        self.alpha = self.alpha.to(device)
        self.alpha_hat = self.alpha_hat.to(device)
        return self

    def add_noise(self, x: torch.Tensor, t: torch.Tensor):
        t = t.long()
        sqrt_alpha_hat = torch.sqrt(self.alpha_hat[t])[:, None, None, None]
        sqrt_one_minus_alpha_hat = torch.sqrt(1 - self.alpha_hat[t])[:, None, None, None]
        eps = torch.randn_like(x)
        return sqrt_alpha_hat * x + sqrt_one_minus_alpha_hat * eps, eps

    @torch.no_grad()
    def sample(self, model, conditions: torch.Tensor, device: str, size=None):
        model.eval()
        if size is None:
            size = (conditions.shape[0], 1, conditions.shape[2], conditions.shape[3])

        x = torch.randn(size, device=device).float()
        conditions = conditions.to(device).float()

        for t in range(self.timesteps - 1, -1, -1):
            tt = torch.full((size[0],), t, dtype=torch.long, device=device)
            predicted_noise = model(x, tt, conditions)

            alpha = self.alpha[t]
            alpha_hat = self.alpha_hat[t]
            beta = self.beta[t]

            noise = torch.randn_like(x) if t > 0 else 0.0
            x = (1 / torch.sqrt(alpha)) * (
                x - ((1 - alpha) / torch.sqrt(1 - alpha_hat)) * predicted_noise
            ) + torch.sqrt(beta) * noise

        return x
